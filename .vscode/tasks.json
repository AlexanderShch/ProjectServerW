{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PlatformIO: Build",
            "type": "shell",
            "command": "pio",
            "args": [
                "run"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$platformio"
            ]
        },
        {
            "label": "PlatformIO: Upload",
            "type": "shell",
            "command": "pio",
            "args": [
                "run",
                "--target",
                "upload"
            ],
            "problemMatcher": [
                "$platformio"
            ]
        },
        {
            "label": "PlatformIO: Clean",
            "type": "shell",
            "command": "pio",
            "args": [
                "run",
                "--target",
                "clean"
            ],
            "problemMatcher": [
                "$platformio"
            ]
        }
    ]
}

